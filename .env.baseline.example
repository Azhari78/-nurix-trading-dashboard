# Baseline profile overrides
# Use with: ./switch_profile.sh baseline

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
AUTO_TRADE_STRATEGY_MODE=long_only
AUTO_TRADE_ENABLE_SHORT=false
AUTO_TRADE_MAX_OPEN_POSITIONS=1

# Use fixed size for slower, more consistent exposure.
TRADE_SIZE_USDT=20
TRADE_SIZE_USDT_MIN=10
TRADE_SIZE_USDT_MAX=30
TRADE_SIZE_PERCENT=0

# Tighter daily risk cap.
MAX_DAILY_LOSS_USDT=30
