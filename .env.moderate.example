# Moderate profile overrides
# Use with: ./switch_profile.sh moderate

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
AUTO_TRADE_MAX_OPEN_POSITIONS=2

# Balanced sizing: capped and partially percent-based.
TRADE_SIZE_USDT=15
TRADE_SIZE_USDT_MIN=10
TRADE_SIZE_USDT_MAX=35
TRADE_SIZE_PERCENT=3

# Guardrails for balanced frequency and quality.
MAX_DAILY_LOSS_USDT=35
AUTO_TRADE_ENTRY_CONFIRM_MACD=true
AUTO_TRADE_MIN_VOLUME_RATIO=0.55
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=25
LONG_RSI_MIN=45
LONG_RSI_MAX=64
SHORT_RSI_MIN=58
SHORT_RSI_MAX=75
AI_FILTER_MIN_CONFIDENCE=52
AI_FILTER_MIN_SCORE_ABS=0.8
AUTO_TRADE_EXECUTION_COST_GATE_ENABLED=true
AUTO_TRADE_MAX_SPREAD_PCT=0.16
AUTO_TRADE_ESTIMATED_FEE_PCT=0.08
AUTO_TRADE_ESTIMATED_SLIPPAGE_PCT=0.06
AUTO_TRADE_MIN_EDGE_PCT=0.10
AUTO_TRADE_SYMBOL_RANK_ENABLED=true
AUTO_TRADE_SYMBOL_RANK_TOP_N=2
AUTO_TRADE_PARTIAL_TP_ENABLED=true
AUTO_TRADE_TIME_STOP_ENABLED=true
AUTO_TRADE_TIME_STOP_MINUTES=12
AUTO_TRADE_TIME_STOP_MIN_PNL_PCT=0.08
AUTO_TRADE_AUTO_ADAPT_ENABLED=true
COOLDOWN_SECONDS=240
COOLDOWN_MIN_SECONDS=180
COOLDOWN_MAX_SECONDS=360
