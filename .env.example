# Exchange options: gateio (recommended), binance
EXCHANGE_NAME=gateio

# Comma-separated watchlist symbols
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,TRX/USDT,AVAX/USDT,LINK/USDT,DOT/USDT,POL/USDT,LTC/USDT,BCH/USDT,XLM/USDT,ATOM/USDT,XMR/USDT,ETC/USDT,UNI/USDT,FIL/USDT,HBAR/USDT,NEAR/USDT,ICP/USDT,VET/USDT,CRO/USDT,ALGO/USDT,SUI/USDT,INJ/USDT,APT/USDT,OP/USDT,ARB/USDT,RNDR/USDT,IMX/USDT,STX/USDT,MKR/USDT,AAVE/USDT,THETA/USDT,EOS/USDT,EGLD/USDT,MANA/USDT,SAND/USDT,FTM/USDT,TIA/USDT,PEPE/USDT,SHIB/USDT,BONK/USDT,GRT/USDT,LDO/USDT,FLOW/USDT,SEI/USDT

# Supported: 1m, 5m, 15m, 1h, 4h
DEFAULT_TIMEFRAME=1m

# Exchange websocket SSL settings
STREAM_SSL_VERIFY=true
# Optional custom CA bundle path. Leave empty to use built-in certifi bundle.
STREAM_SSL_CA_BUNDLE=

# Exchange API credentials (required only for LIVE auto trade)
API_KEY=
API_SECRET=
USE_SANDBOX=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# true = notify auto-trade + alert-builder triggers only
# false = notify all emitted alerts
TELEGRAM_AUTO_TRADE_ONLY=true

# Auto-trade config
AUTO_TRADE_ENABLED=false
PAPER_TRADING=true
# PAPER wallet simulation (works without exchange API key).
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
# Persist paper auto-trade runtime (positions + wallet) between process restarts.
AUTO_TRADE_STATE_FILE=data/auto_trade_state.json
AUTO_TRADE_STATE_SAVE_INTERVAL_SECONDS=5
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,ADA/USDT,BNB/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
# Set <=0 for unlimited open positions.
AUTO_TRADE_MAX_OPEN_POSITIONS=0
# Auto-convert free balances from AUTO_TRADE_SYMBOLS into USDT (LIVE only).
AUTO_TRADE_AUTO_CONVERT_TO_USDT=false
AUTO_TRADE_AUTO_CONVERT_MIN_USDT=3
AUTO_TRADE_AUTO_CONVERT_INTERVAL_SECONDS=120
AUTO_TRADE_SYMBOL_VALIDATION_ENABLED=true
TRADE_SIZE_USDT=9
TRADE_SIZE_USDT_MIN=8
TRADE_SIZE_USDT_MAX=10
# If > 0, each new ENTRY size will use this percent of available USDT balance.
# Example: 5 means each new trade uses 5% from free USDT.
TRADE_SIZE_PERCENT=0
# Volatility-adjusted sizing (ATR%)
AUTO_TRADE_VOLATILITY_SIZING_ENABLED=true
AUTO_TRADE_TARGET_ATR_PCT=0.9
AUTO_TRADE_VOLATILITY_SIZE_MIN_MULT=0.55
AUTO_TRADE_VOLATILITY_SIZE_MAX_MULT=1.65
# Safety floor for order notional in USDT. Gate.io common minimum is around 3.
AUTO_TRADE_MIN_NOTIONAL_USDT=3
# Extra buffer (%) above minimum notional to avoid precision rounding rejects.
AUTO_TRADE_MIN_BUFFER_PCT=1.5
# Layered entry confirmation filters
AUTO_TRADE_ENTRY_CONFIRM_EMA_STACK=true
AUTO_TRADE_ENTRY_CONFIRM_MACD=true
AUTO_TRADE_MIN_VOLUME_RATIO=0.8
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=25
# Session/news-proxy filters
AUTO_TRADE_SESSION_FILTER_ENABLED=false
# Format examples: 0-23, 7-11,13-17
AUTO_TRADE_SESSION_UTC=0-23
AUTO_TRADE_EXTREME_VOLATILITY_BLOCK_ENABLED=true
AUTO_TRADE_MAX_ATR_PCT=5.5
AUTO_TRADE_MAX_ABS_CHANGE_24H_PCT=20
# Execution-cost gate (spread + fee + slippage vs TP edge)
AUTO_TRADE_EXECUTION_COST_GATE_ENABLED=true
AUTO_TRADE_MAX_SPREAD_PCT=0.12
AUTO_TRADE_ESTIMATED_FEE_PCT=0.08
AUTO_TRADE_ESTIMATED_SLIPPAGE_PCT=0.05
AUTO_TRADE_MIN_EDGE_PCT=0.12
# Rank symbols each cycle and only take top-N setups
AUTO_TRADE_SYMBOL_RANK_ENABLED=true
AUTO_TRADE_SYMBOL_RANK_TOP_N=2
STOP_LOSS_PCT=5.0
TAKE_PROFIT_PCT=10.0
LONG_RSI_MIN=45
LONG_RSI_MAX=60
LONG_STOP_LOSS_PCT=5.0
LONG_TAKE_PROFIT_PCT=10.0
LONG_TRAILING_PCT=5.0
SHORT_RSI_MIN=60
SHORT_RSI_MAX=75
SHORT_STOP_LOSS_PCT=4.0
SHORT_TAKE_PROFIT_PCT=7.0
SHORT_TRAILING_PCT=4.0
# Exit once unrealized PnL reaches this minimum percent (0 = any profit).
AUTO_TRADE_TP_AND_RUN_ENABLED=true
AUTO_TRADE_TP_AND_RUN_MIN_PNL_PCT=0.0
# Smart exits (partial TP + break-even)
AUTO_TRADE_PARTIAL_TP_ENABLED=true
AUTO_TRADE_PARTIAL_TP_PCT=3.0
AUTO_TRADE_PARTIAL_TP_RATIO=0.5
AUTO_TRADE_BREAK_EVEN_ENABLED=true
AUTO_TRADE_BREAK_EVEN_TRIGGER_PCT=1.25
AUTO_TRADE_BREAK_EVEN_BUFFER_PCT=0.1
# Exit stale trades that fail to progress after N minutes
AUTO_TRADE_TIME_STOP_ENABLED=true
AUTO_TRADE_TIME_STOP_MINUTES=15
AUTO_TRADE_TIME_STOP_MIN_PNL_PCT=0.15
COOLDOWN_SECONDS=600
COOLDOWN_MIN_SECONDS=600
COOLDOWN_MAX_SECONDS=900
AUTO_TRADE_COOLDOWN_ADAPTIVE_ENABLED=true
AUTO_TRADE_COOLDOWN_LOSS_STEP_MULT=0.35
AUTO_TRADE_COOLDOWN_VOL_TARGET_ATR_PCT=0.9
AUTO_TRADE_COOLDOWN_VOL_MAX_MULT=3.0
AUTO_TRADE_MAX_CONSECUTIVE_LOSSES=3
AUTO_TRADE_KILL_SWITCH_PAUSE_SECONDS=1800
MAX_DAILY_LOSS_USDT=50
AUTO_TRADE_MIN_CONFIDENCE=55
# Forward-test guardrail (7-day performance)
AUTO_TRADE_FORWARD_GUARDRAIL_ENABLED=true
AUTO_TRADE_FORWARD_GUARDRAIL_MIN_TRADES=14
AUTO_TRADE_FORWARD_BASELINE_WIN_RATE=0.5
AUTO_TRADE_FORWARD_BASELINE_AVG_PNL_USDT=0
AUTO_TRADE_FORWARD_GUARDRAIL_RISK_MULT=0.6
AUTO_TRADE_FORWARD_GUARDRAIL_SEVERE_WIN_RATE=0.35
AUTO_TRADE_FORWARD_GUARDRAIL_HALT_ENABLED=false

# AI filter (rule-based scoring gate)
AI_FILTER_ENABLED=true
AI_FILTER_MIN_CONFIDENCE=55
AI_FILTER_MIN_SCORE_ABS=1.0

# Auto-adapt profile (AGGRESSIVE / BALANCED / DEFENSIVE)
AUTO_TRADE_AUTO_ADAPT_ENABLED=true
AUTO_TRADE_AUTO_ADAPT_LOW_ATR_PCT=0.9
AUTO_TRADE_AUTO_ADAPT_HIGH_ATR_PCT=2.2
AUTO_TRADE_AUTO_ADAPT_CONF_STEP=8
AUTO_TRADE_AUTO_ADAPT_RISK_ON_MULT=1.15
AUTO_TRADE_AUTO_ADAPT_RISK_OFF_MULT=0.7
AUTO_TRADE_AUTO_ADAPT_COOLDOWN_ON_MULT=0.8
AUTO_TRADE_AUTO_ADAPT_COOLDOWN_OFF_MULT=1.4

# Copy trade followers format: name:multiplier,name2:multiplier
COPY_TRADE_ENABLED=false
COPY_TRADE_FOLLOWERS=alpha:1.0,beta:0.5
COPY_TRADE_SLIPPAGE_BPS=4
