# High-winrate profile overrides
# Use with: ./switch_profile.sh winrate
#
# Goal:
# - Higher signal quality and cleaner dashboard win rate
# - Lower whipsaw exits
# - Keep upside in trending markets via wider TP + trailing
#
# Pair with: SIGNAL_TIMEFRAME=5m

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=20000

# Focus on the most liquid majors for cleaner fills.
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT
AUTO_TRADE_STRATEGY_MODE=long_only
AUTO_TRADE_ENABLE_SHORT=false
AUTO_TRADE_MAX_OPEN_POSITIONS=1

# Keep your current fixed exposure style.
TRADE_SIZE_USDT=100
TRADE_SIZE_USDT_MIN=100
TRADE_SIZE_USDT_MAX=100
TRADE_SIZE_PERCENT=0

# Stricter entry quality
AUTO_TRADE_ENTRY_CONFIRM_MACD=true
AUTO_TRADE_ENTRY_REQUIRE_MACD_DATA=true
AUTO_TRADE_MIN_VOLUME_RATIO=1.2
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=50
LONG_RSI_MIN=50
LONG_RSI_MAX=59
AI_FILTER_MIN_CONFIDENCE=68
AI_FILTER_MIN_SCORE_ABS=1.4

# Execution quality gate
AUTO_TRADE_EXECUTION_COST_GATE_ENABLED=true
AUTO_TRADE_MAX_SPREAD_PCT=0.06
AUTO_TRADE_ESTIMATED_FEE_PCT=0.08
AUTO_TRADE_ESTIMATED_SLIPPAGE_PCT=0.06
AUTO_TRADE_MIN_EDGE_PCT=0.30
AUTO_TRADE_SYMBOL_RANK_ENABLED=true
AUTO_TRADE_SYMBOL_RANK_TOP_N=1

# Exit tuning: let winners run, cut chop slower
LONG_STOP_LOSS_PCT=1.8
LONG_TAKE_PROFIT_PCT=3.0
LONG_TRAILING_PCT=1.0
AUTO_TRADE_TP_AND_RUN_ENABLED=true
AUTO_TRADE_TP_AND_RUN_MIN_PNL_PCT=0.8
AUTO_TRADE_PARTIAL_TP_ENABLED=true
AUTO_TRADE_PARTIAL_TP_PCT=1.3
AUTO_TRADE_PARTIAL_TP_RATIO=0.5
AUTO_TRADE_BREAK_EVEN_ENABLED=true
AUTO_TRADE_BREAK_EVEN_TRIGGER_PCT=0.7
AUTO_TRADE_BREAK_EVEN_BUFFER_PCT=0.08
AUTO_TRADE_TIME_STOP_ENABLED=true
AUTO_TRADE_TIME_STOP_MINUTES=35
AUTO_TRADE_TIME_STOP_MIN_PNL_PCT=-0.15

# Lower churn / overtrading
AUTO_TRADE_COOLDOWN_ADAPTIVE_ENABLED=true
COOLDOWN_SECONDS=420
COOLDOWN_MIN_SECONDS=300
COOLDOWN_MAX_SECONDS=900

# Keep risk controls on
AUTO_TRADE_AUTO_ADAPT_ENABLED=true
AUTO_TRADE_MAX_CONSECUTIVE_LOSSES=3
MAX_DAILY_LOSS_USDT=50
AUTO_TRADE_FORWARD_GUARDRAIL_ENABLED=true
AUTO_TRADE_FORWARD_GUARDRAIL_MIN_TRADES=14
AUTO_TRADE_FORWARD_BASELINE_WIN_RATE=0.52
AUTO_TRADE_FORWARD_BASELINE_AVG_PNL_USDT=0.03
AUTO_TRADE_FORWARD_GUARDRAIL_RISK_MULT=0.6
AUTO_TRADE_FORWARD_GUARDRAIL_SEVERE_WIN_RATE=0.35
AUTO_TRADE_FORWARD_GUARDRAIL_HALT_ENABLED=false
