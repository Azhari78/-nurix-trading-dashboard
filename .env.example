# Exchange options: gateio (recommended), binance
EXCHANGE_NAME=gateio

# Comma-separated watchlist symbols
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,TRX/USDT,AVAX/USDT,LINK/USDT,DOT/USDT,POL/USDT,LTC/USDT,BCH/USDT,XLM/USDT,ATOM/USDT,XMR/USDT,ETC/USDT,UNI/USDT,FIL/USDT,HBAR/USDT,NEAR/USDT,ICP/USDT,VET/USDT,CRO/USDT,ALGO/USDT,SUI/USDT,INJ/USDT,APT/USDT,OP/USDT,ARB/USDT,RNDR/USDT,IMX/USDT,STX/USDT,MKR/USDT,AAVE/USDT,THETA/USDT,EOS/USDT,EGLD/USDT,MANA/USDT,SAND/USDT,FTM/USDT,TIA/USDT,PEPE/USDT,SHIB/USDT,BONK/USDT,GRT/USDT,LDO/USDT,FLOW/USDT,SEI/USDT

# Supported: 1m, 5m, 15m, 1h, 4h
DEFAULT_TIMEFRAME=1m

# Exchange websocket SSL settings
STREAM_SSL_VERIFY=true
# Optional custom CA bundle path. Leave empty to use built-in certifi bundle.
STREAM_SSL_CA_BUNDLE=

# Exchange API credentials (required only for LIVE auto trade)
API_KEY=
API_SECRET=
USE_SANDBOX=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# true = notify auto-trade alerts only (ENTRY/EXIT/ERROR/HALT)
# false = notify all emitted alerts
TELEGRAM_AUTO_TRADE_ONLY=true

# Auto-trade config
AUTO_TRADE_ENABLED=false
PAPER_TRADING=true
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
AUTO_TRADE_MAX_OPEN_POSITIONS=2
TRADE_SIZE_USDT=9
TRADE_SIZE_USDT_MIN=8
TRADE_SIZE_USDT_MAX=10
# If > 0, each new ENTRY size will use this percent of available USDT balance.
# Example: 5 means each new trade uses 5% from free USDT.
TRADE_SIZE_PERCENT=0
# Safety floor for order notional in USDT. Gate.io common minimum is around 3.
AUTO_TRADE_MIN_NOTIONAL_USDT=3
# Extra buffer (%) above minimum notional to avoid precision rounding rejects.
AUTO_TRADE_MIN_BUFFER_PCT=1.5
STOP_LOSS_PCT=5.0
TAKE_PROFIT_PCT=10.0
LONG_RSI_MIN=45
LONG_RSI_MAX=60
LONG_STOP_LOSS_PCT=5.0
LONG_TAKE_PROFIT_PCT=10.0
LONG_TRAILING_PCT=5.0
SHORT_RSI_MIN=60
SHORT_RSI_MAX=75
SHORT_STOP_LOSS_PCT=4.0
SHORT_TAKE_PROFIT_PCT=7.0
SHORT_TRAILING_PCT=4.0
COOLDOWN_SECONDS=600
COOLDOWN_MIN_SECONDS=600
COOLDOWN_MAX_SECONDS=900
MAX_DAILY_LOSS_USDT=50
AUTO_TRADE_MIN_CONFIDENCE=55

# AI filter (rule-based scoring gate)
AI_FILTER_ENABLED=true
AI_FILTER_MIN_CONFIDENCE=55
AI_FILTER_MIN_SCORE_ABS=1.0
