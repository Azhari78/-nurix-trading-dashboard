# Moderate profile overrides (tightened)
# Use with: ./switch_profile.sh moderate

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
AUTO_TRADE_MAX_OPEN_POSITIONS=1

# Balanced sizing: smaller and fixed for lower variance.
TRADE_SIZE_USDT=15
TRADE_SIZE_USDT_MIN=10
TRADE_SIZE_USDT_MAX=20
TRADE_SIZE_PERCENT=0

# Guardrails for better trade quality.
DEFAULT_TIMEFRAME=5m
MAX_DAILY_LOSS_USDT=20
AUTO_TRADE_ENTRY_CONFIRM_MACD=true
AUTO_TRADE_MIN_VOLUME_RATIO=1.0
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=40
LONG_RSI_MIN=47
LONG_RSI_MAX=60
SHORT_RSI_MIN=62
SHORT_RSI_MAX=73
LONG_STOP_LOSS_PCT=2.2
LONG_TAKE_PROFIT_PCT=3.5
LONG_TRAILING_PCT=1.2
SHORT_STOP_LOSS_PCT=2.0
SHORT_TAKE_PROFIT_PCT=3.2
SHORT_TRAILING_PCT=1.1
AUTO_TRADE_TP_AND_RUN_ENABLED=true
AUTO_TRADE_TP_AND_RUN_MIN_PNL_PCT=0.0
AUTO_TRADE_PARTIAL_TP_PCT=1.4
AUTO_TRADE_BREAK_EVEN_TRIGGER_PCT=0.8
AUTO_TRADE_BREAK_EVEN_BUFFER_PCT=0.05
AUTO_TRADE_TIME_STOP_ENABLED=true
AUTO_TRADE_TIME_STOP_MINUTES=20
AUTO_TRADE_TIME_STOP_MIN_PNL_PCT=0.00
AI_FILTER_MIN_CONFIDENCE=62
AI_FILTER_MIN_SCORE_ABS=1.2
AUTO_TRADE_EXECUTION_COST_GATE_ENABLED=true
AUTO_TRADE_MAX_SPREAD_PCT=0.10
AUTO_TRADE_ESTIMATED_FEE_PCT=0.08
AUTO_TRADE_ESTIMATED_SLIPPAGE_PCT=0.06
AUTO_TRADE_MIN_EDGE_PCT=0.25
AUTO_TRADE_SYMBOL_RANK_ENABLED=true
AUTO_TRADE_SYMBOL_RANK_TOP_N=1
AUTO_TRADE_PARTIAL_TP_ENABLED=true
AUTO_TRADE_AUTO_ADAPT_ENABLED=true
COOLDOWN_SECONDS=480
COOLDOWN_MIN_SECONDS=360
COOLDOWN_MAX_SECONDS=720
AUTO_TRADE_MAX_CONSECUTIVE_LOSSES=3
