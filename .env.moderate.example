# Moderate profile overrides
# Use with: ./switch_profile.sh moderate

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
AUTO_TRADE_MAX_OPEN_POSITIONS=2

# Balanced sizing: capped and partially percent-based.
TRADE_SIZE_USDT=15
TRADE_SIZE_USDT_MIN=10
TRADE_SIZE_USDT_MAX=35
TRADE_SIZE_PERCENT=3

# Guardrails for balanced frequency and quality.
MAX_DAILY_LOSS_USDT=35
AUTO_TRADE_ENTRY_CONFIRM_MACD=true
AUTO_TRADE_MIN_VOLUME_RATIO=0.7
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=30
LONG_RSI_MIN=45
LONG_RSI_MAX=62
SHORT_RSI_MIN=60
SHORT_RSI_MAX=75
AI_FILTER_MIN_CONFIDENCE=55
AI_FILTER_MIN_SCORE_ABS=0.9
AUTO_TRADE_PARTIAL_TP_ENABLED=true
AUTO_TRADE_AUTO_ADAPT_ENABLED=true
