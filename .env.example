# Exchange options: gateio (recommended), binance
EXCHANGE_NAME=gateio

# Comma-separated watchlist symbols
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,TRX/USDT,AVAX/USDT,LINK/USDT

# Supported: 1m, 5m, 15m, 1h, 4h
DEFAULT_TIMEFRAME=1m

# Exchange websocket SSL settings
STREAM_SSL_VERIFY=true
# Optional custom CA bundle path. Leave empty to use built-in certifi bundle.
STREAM_SSL_CA_BUNDLE=

# Exchange API credentials (required only for LIVE auto trade)
API_KEY=
API_SECRET=
USE_SANDBOX=false

# Auto-trade config
AUTO_TRADE_ENABLED=false
PAPER_TRADING=true
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TRADE_SIZE_USDT=20
# If > 0, BUY size will use this percent of available USDT balance.
# Example: 5 means each new BUY uses 5% from free USDT.
TRADE_SIZE_PERCENT=0
# Safety floor for order notional in USDT. Gate.io common minimum is around 3.
AUTO_TRADE_MIN_NOTIONAL_USDT=3
# Extra buffer (%) above minimum notional to avoid precision rounding rejects.
AUTO_TRADE_MIN_BUFFER_PCT=1.5
STOP_LOSS_PCT=1.0
TAKE_PROFIT_PCT=2.0
COOLDOWN_SECONDS=300
MAX_DAILY_LOSS_USDT=50
AUTO_TRADE_MIN_CONFIDENCE=55
