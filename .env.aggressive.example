# Aggressive profile overrides
# Use with: ./switch_profile.sh aggressive

PAPER_TRADING=true
PAPER_WALLET_ENABLED=true
PAPER_WALLET_START_USDT=10000
AUTO_TRADE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT
AUTO_TRADE_STRATEGY_MODE=both
AUTO_TRADE_ENABLE_SHORT=true
AUTO_TRADE_MAX_OPEN_POSITIONS=2

# Use percentage sizing for faster capital deployment.
TRADE_SIZE_USDT=35
TRADE_SIZE_USDT_MIN=15
TRADE_SIZE_USDT_MAX=75
TRADE_SIZE_PERCENT=10

# Wider daily loss limit for higher activity profile.
MAX_DAILY_LOSS_USDT=60

# Entry tuning (more frequent entries)
AUTO_TRADE_ENTRY_CONFIRM_MACD=false
AUTO_TRADE_MIN_VOLUME_RATIO=0.35
AUTO_TRADE_MIN_STRENGTH_CONFIDENCE=20
LONG_RSI_MIN=42
LONG_RSI_MAX=65
SHORT_RSI_MIN=58
SHORT_RSI_MAX=78
AI_FILTER_MIN_CONFIDENCE=45
AI_FILTER_MIN_SCORE_ABS=0.6

# Exit terus bila posisi sudah untung.
AUTO_TRADE_TP_AND_RUN_ENABLED=true
