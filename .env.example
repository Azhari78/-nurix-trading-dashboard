# Binance API credentials (backend only)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Binance base URL
BINANCE_BASE_URL=https://api.binance.com

# Trading API server
# Cloud platforms (Render/Railway/etc) usually inject PORT automatically.
TRADING_BOT_PORT=8787
BINANCE_RECV_WINDOW=5000
TRADING_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Safety gate for real orders
# false = allow TEST orders only
# true  = allow LIVE orders
ENABLE_LIVE_ORDERS=false

# Optional frontend override
# In production static hosting, set this to your backend URL.
VITE_TRADING_API_URL=
# VITE_TRADING_API_PROXY_TARGET=http://localhost:8787
